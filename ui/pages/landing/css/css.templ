package css

const (
	GlassCard = "bg-gray-200 backdrop-blur-lg border border-gray-200 shadow-sm"
)

css AnimateBounce() {
    animation: pinBounce 2.5s cubic-bezier(0.23, 1, 0.32, 1) infinite;
}

css AnimateLiveGlow() {
    animation: liveGlow 2s ease-in-out infinite;
}

css AnimateEtaPulse() {
    animation: etaPulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}
